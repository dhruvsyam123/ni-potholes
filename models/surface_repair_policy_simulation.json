{
  "model": "models/surface_recurrence_best.joblib",
  "target": "repeat_within_14d_200m",
  "holdout": {
    "date_rule": "> 2017-09-30 and <= 2018-03-17 11:34:00",
    "n": 49360,
    "observed_target_positive_rate": 0.5689019448946515
  },
  "simulation_definition": {
    "baseline": "Every observed holdout defect occurs and costs event_cost.",
    "policy": "If an occurring defect has model risk >= threshold, pay intervention_premium and probabilistically suppress future defects within radius and suppression horizon.",
    "radius_m": 200.0,
    "caveat": "This is a counterfactual simulation, not causal proof, because the open data does not contain actual intervention timings, repair types, or repair outcomes."
  },
  "scenarios": [
    {
      "name": "repair_only_14d_conservative",
      "event_cost": 87.8,
      "intervention_premium": 30.86,
      "effectiveness": 0.5,
      "suppression_horizon_days": 14,
      "description": "Authority repair budget only. Each prevented future defect avoids one average reactive fill. Intervention premium is the ALARM reactive-minus-planned cost delta."
    },
    {
      "name": "repair_only_14d_good_fix",
      "event_cost": 87.8,
      "intervention_premium": 30.86,
      "effectiveness": 0.75,
      "suppression_horizon_days": 14,
      "description": "Same costs as above, but assumes good repair quality prevents 75% of short-window repeats."
    },
    {
      "name": "authority_plus_admin_14d",
      "event_cost": 155.3,
      "intervention_premium": 75.0,
      "effectiveness": 0.6,
      "suppression_horizon_days": 14,
      "description": "Authority-centric case including reactive repair plus modest inspection/admin/claim handling burden."
    },
    {
      "name": "moderate_asset_30d",
      "event_cost": 272.8,
      "intervention_premium": 125.0,
      "effectiveness": 0.6,
      "suppression_horizon_days": 30,
      "description": "Moderate asset-management case: prevents nearby repeats over 30 days and includes some deterioration/road-user externality in avoided event cost."
    },
    {
      "name": "strong_asset_90d",
      "event_cost": 579.8,
      "intervention_premium": 300.0,
      "effectiveness": 0.6,
      "suppression_horizon_days": 90,
      "description": "Stronger asset-effect case: expensive intervention but assumed to suppress local defect recurrence for a quarter."
    },
    {
      "name": "medium_patch_premium_90d_stress",
      "event_cost": 579.8,
      "intervention_premium": 1240.2,
      "effectiveness": 0.6,
      "suppression_horizon_days": 90,
      "description": "Stress test: medium patch premium approximated as \u00a31,328 minus one average reactive fill. Only viable if broader benefits are large."
    }
  ],
